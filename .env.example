# Copy to .env and adjust. Both binaries read the same variables (see internal/config).

CRDB_DSN=postgresql://root@127.0.0.1:26257/defaultdb?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
REDIS_KEY_PREFIX=dto:

# Avoid clashing with CockroachDB UI mapped to host port 8089 in docker-compose.yml
ORCHESTRATOR_LISTEN=:8080

RECONCILE_INTERVAL=30s
LEASE_DURATION=30s
RETRY_BACKOFF=5s
WORKER_CONCURRENCY=1
